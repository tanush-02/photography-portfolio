# Static Admin Credentials
# Change these to your desired admin username and password
REACT_APP_ADMIN_USERNAME=admin
REACT_APP_ADMIN_PASSWORD=admin123

# Cloudinary Configuration
# Get these values from Cloudinary Dashboard: https://cloudinary.com/console
# Cloud Name: Found in Dashboard
# API Key & Secret: Found in Dashboard > Settings > Access Keys
# Upload Preset: Create in Dashboard > Settings > Upload > Upload presets (set to "unsigned" for client-side uploads)

REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
REACT_APP_CLOUDINARY_API_KEY=your_api_key_here
REACT_APP_CLOUDINARY_API_SECRET=your_api_secret_here
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here